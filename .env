# ============================================================================
# LLM Provider Configuration
# ============================================================================
# Choose ONE provider: anthropic, openai, gemini, lmstudio, or ollama

# --- Option 1: Google Gemini (Recommended for free tier)
LLM_PROVIDER=gemini
GEMINI_API_KEY=AIzaSyDJJAweAmuUmXL5DaNRe1X_Az7Gc9jkjJw
LLM_MODEL_GEMINI=gemini-2.0-flash
# Get free API key: https://ai.google.dev/

# --- Option 2: LM Studio (Local, No API Key, Private)
# Requires LM Studio running on your machine
# Download: https://lmstudio.ai/
# LLM_PROVIDER=lmstudio
# LLM_MODEL_LMSTUDIO=nvidia/nemotron-3-nano-4b
# (LM Studio runs on http://localhost:1234 by default)

# --- Option 3: OpenAI (Paid)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# LLM_MODEL_OPENAI=gpt-4o-mini

# --- Option 4: Anthropic Claude (Paid)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL_ANTHROPIC=claude-3-5-haiku-20241022

# --- Option 5: Ollama (Local)
# Requires Ollama running on your machine
# Download: https://ollama.ai/
# LLM_PROVIDER=ollama
# LLM_MODEL_OLLAMA=llama3

LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# ============================================================================
# Database Configuration
# ============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=querygpt
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_POOL_MIN=1
DB_POOL_MAX=10

# ============================================================================
# Embedding Provider Configuration
# ============================================================================
# Currently supports: openai, local
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ============================================================================
# Vector Store Configuration
# ============================================================================
# Currently supports: memory, pgvector
VECTOR_STORE=memory
# If using pgvector:
# VECTOR_STORE=pgvector
# (Uses DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD from above)

VS_TOP_K_SCHEMAS=5
VS_TOP_K_SAMPLES=7

# ============================================================================
# Custom Instructions
# ============================================================================
# Add custom instructions for SQL generation (optional)
# CUSTOM_INSTRUCTIONS="Always use explicit table aliases. Prefer INNER JOINs."
